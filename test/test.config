params {
    // Test configuration for compost pipeline
    // Input BAM file (pointing to test data)
    bam = "$projectDir/test/data/demo_scaffold_masked.bam"
    strandedness = "reverse"
    scaf_keyword = "scaf"
    // activate trans spliced mode
    trans_spliced = "true"

    // GTF annotation file
    gtf = "$projectDir/test/data/mlei_test.gtf"

    // homopolymers bed
    homopol = "$projectDir/test/data/mlei_a7_chr_8.bed"

    // Peak depth parameter
    peak_depth = 25

    // Output directory
    outdir = "$projectDir/test/testDevelop24Apr"
}
env {
    PYTHONPATH = "${projectDir}/packages"
}

process {
    beforeScript = 'source /etc/profile.d/modules.sh && module load R HTSlib SAMtools'
}
